From 0905288633e863c8b66b4859a9be1a3fe49de19c Mon Sep 17 00:00:00 2001
From: Bruno Ernesto Russo <root@synex.ar>
Date: Sat, 13 Jun 2026 23:06:01 -0300
Subject: [PATCH 1/2] Synex: replace network-manager-gnome with
 nm-connection-editor (avoids duplicate nm-applet in COSMIC)

---
 debian/control | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/debian/control b/debian/control
index c04ab78..23894b7 100644
--- a/debian/control
+++ b/debian/control
@@ -31,7 +31,7 @@ Depends:
     cosmic-randr,
     gettext,
     iso-codes,
-    network-manager-gnome,
+    nm-connection-editor,
     network-manager-openvpn,
     network-manager-openvpn-gnome,
     xkb-data,
-- 
2.47.3


